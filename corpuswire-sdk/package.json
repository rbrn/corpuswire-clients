{
  "name": "@corpuswire/sdk",
  "version": "0.1.3",
  "description": "Zero-dependency Node/TypeScript SDK for CorpusWire retrieval, prompt enhancement, and remote indexing",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "examples",
    "README.md",
    "tsconfig.json"
  ],
  "scripts": {
    "test": "node --test tests/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rbrn/corpuswire.git",
    "directory": "clients/corpuswire-sdk"
  },
  "homepage": "https://github.com/rbrn/corpuswire/tree/main/clients/corpuswire-sdk",
  "bugs": {
    "url": "https://github.com/rbrn/corpuswire/issues"
  },
  "keywords": [
    "corpuswire",
    "semantic-search",
    "rag",
    "context-engine",
    "remote-indexing"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  }
}
